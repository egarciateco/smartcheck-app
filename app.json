{
  "expo": {
    "name": "SmartCheck",
    "slug": "smartcheck-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#001f3f"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartcheck.supermercados"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#001f3f"
      },
      "package": "com.smartcheck.supermercados"
    },
    "web": {
      "favicon": "./assets/logo.png"
    }
  }
}
